#!/usr/bin/env python3
"""
Unified check runner. Reads registry.json, filters by --tier, runs each check.

Tiers:
  static   — grep source files (no infra)
  env      — compare env vars across containers (needs docker/kubectl)
  health   — curl service endpoints (needs network)
  contract — test API behavior (needs network + credentials)

Usage:
  ./checks/run --tier static
  ./checks/run --tier env
  ./checks/run --tier health
  ./checks/run --tier contract
  ./checks/run                   # all tiers
"""

import json
import os
import re
import subprocess
import sys

ROOT = os.environ.get("ROOT", subprocess.check_output(
    ["git", "rev-parse", "--show-toplevel"], text=True).strip())
STATE = os.environ.get("STATE", os.path.join(ROOT, "tests3", ".state"))
REGISTRY = os.path.join(ROOT, "tests3", "checks", "registry.json")

os.makedirs(STATE, exist_ok=True)


LOG_FILE = os.path.join(STATE, "tests3.log")

def red(s):   return f"\033[31m{s}\033[0m"
def green(s): return f"\033[32m{s}\033[0m"
def dim(s):   return f"\033[90m{s}\033[0m"


def log(level, check_id, message, detail=""):
    """Append a timestamped line to the log file."""
    from datetime import datetime
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {level:<4} {check_id}: {message}"
    if detail:
        line += f" | {detail}"
    with open(LOG_FILE, "a") as f:
        f.write(line + "\n")


def state_read(key, required=False):
    path = os.path.join(STATE, key)
    if os.path.isfile(path):
        return open(path).read().strip()
    if required:
        print(f"  {red('ERROR')}: missing state: {key} (run 'make detect' first)")
        sys.exit(1)
    return ""


def svc_exec(svc, cmd):
    """Run command inside a service container. Returns (exit_code, stdout)."""
    mode = state_read("deploy_mode", required=True)
    if mode == "compose":
        full = ["docker", "exec", f"vexa-{svc}-1"] + cmd
    elif mode == "lite":
        # Container may be named "vexa" or "vexa-lite"
        r = subprocess.run(
            ["docker", "ps", "--format", "{{.Names}}"],
            capture_output=True, text=True, timeout=5,
        )
        cname = next(
            (n for n in r.stdout.strip().splitlines() if n in ("vexa", "vexa-lite")),
            "vexa-lite",
        )
        full = ["docker", "exec", cname] + cmd
    elif mode == "helm":
        release = state_read("helm_release")
        deploy_name = f"{release}-vexa-{svc}" if release else svc
        full = ["kubectl", "exec", f"deploy/{deploy_name}", "--"] + cmd
    else:
        return 1, f"unknown mode: {mode}"

    try:
        r = subprocess.run(full, capture_output=True, text=True, timeout=10)
        return r.returncode, r.stdout.strip()
    except Exception as e:
        return 1, str(e)


def http_check(url, expect_code=200, headers=None):
    """Curl a URL. Returns (actual_code, body)."""
    cmd = ["curl", "-sf", "-w", "\n%{http_code}", "-o", "-"]
    for h in (headers or []):
        cmd += ["-H", h]
    cmd.append(url)
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
        lines = r.stdout.strip().rsplit("\n", 1)
        body = lines[0] if len(lines) > 1 else ""
        code = int(lines[-1]) if lines[-1].isdigit() else 0
        return code, body
    except Exception as e:
        return 0, str(e)


# ─── Tier runners ────────────────────────────────────────────────

def check_static(lock):
    """Grep source file for must_match / must_not_match, or run special static checks."""
    # Branch filter: skip checks that only apply to specific branches
    only_branches = lock.get("only_branches")
    if only_branches:
        try:
            branch = subprocess.run(["git", "rev-parse", "--abbrev-ref", "HEAD"],
                                    capture_output=True, text=True, cwd=ROOT).stdout.strip()
            if branch not in only_branches:
                return True, f"skipped on {branch}"
        except Exception:
            pass

    # Special: helm chart validation (no file to grep, runs CLI commands)
    url = lock.get("url", "")
    if url in ("HELM_LINT", "HELM_TEMPLATE"):
        return check_health(lock)  # delegates to sentinel handler in check_health

    filepath = os.path.join(ROOT, lock["file"])
    if not os.path.isfile(filepath):
        return False, "file missing"

    content = open(filepath).read()
    must = lock.get("must_match", "")
    must_not = lock.get("must_not_match", "")

    if must and must not in content:
        return False, f"expected: {must}"
    if must_not and re.search(must_not, content):
        return False, f"forbidden: {must_not}"
    return True, ""


def check_env(lock):
    """Compare env var values across containers."""
    mode = state_read("deploy_mode", required=True)
    checks = lock.get("env_checks", [])
    for chk in checks:
        svc = chk["service"]
        var = chk["var"]
        code, val = svc_exec(svc, ["printenv", var])
        if code != 0 or not val:
            # In lite mode, supervisor sets per-process env vars invisible to printenv.
            # Skip printenv checks, rely on valid_against to prove it works.
            if mode == "lite" and ("valid_against" in chk or "equals" in chk):
                continue
            if mode == "lite" and chk.get("not_empty"):
                continue  # Can't verify via printenv in lite
            return False, f"{svc}: {var} not set"

        # If 'equals' specified, compare to another service's var
        if "equals" in chk:
            svc2 = chk["equals"]["service"]
            var2 = chk["equals"]["var"]
            code2, val2 = svc_exec(svc2, ["printenv", var2])
            if code2 != 0:
                return False, f"{svc2}: {var2} not set"
            if val != val2:
                return False, f"{svc}.{var}={val!r} != {svc2}.{var2}={val2!r}"

        # If 'valid_against' specified, use the value as a credential
        if "valid_against" in chk:
            url = chk["valid_against"]["url"].replace("$GATEWAY_URL", state_read("gateway_url", required=True))
            url = url.replace("$ADMIN_URL", state_read("admin_url", required=True))
            header = chk["valid_against"]["header"].replace("$VALUE", val)
            code_h, _ = http_check(url, headers=[header])
            if code_h != 200:
                return False, f"{svc}.{var} is invalid (HTTP {code_h} from {url})"

        # If 'not_empty' specified
        if chk.get("not_empty") and not val:
            return False, f"{svc}: {var} is empty"

    return True, ""


def check_health(lock):
    """Curl a service endpoint, check status code."""
    # Skip checks not applicable to current deploy mode
    skip_modes = lock.get("skip_modes", [])
    if skip_modes:
        mode = state_read("deploy_mode")
        if mode in skip_modes:
            return True, f"skipped for {mode} mode"

    url = lock["url"]

    # Special: Transcription health — derive URL from .env or container env
    if url == "TRANSCRIPTION_HEALTH":
        env_file = os.path.join(ROOT, ".env")
        tx_url = ""
        if os.path.isfile(env_file):
            for line in open(env_file):
                if line.startswith("TRANSCRIPTION_SERVICE_URL="):
                    tx_url = line.strip().split("=", 1)[1]
        if not tx_url:
            # Try reading from meeting-api container
            code, val = svc_exec("meeting-api", ["printenv", "TRANSCRIPTION_SERVICE_URL"])
            if code == 0 and val:
                tx_url = val
        if not tx_url:
            return True, "no transcription URL configured — skipped"
        # Replace /v1/audio/transcriptions with /health
        health_url = tx_url.rsplit("/v1/", 1)[0] + "/health" if "/v1/" in tx_url else tx_url + "/health"
        code, body = http_check(health_url)
        if code == 200:
            return True, ""
        return False, f"HTTP {code} from {health_url}"

    # Special: Database integrity checks
    if url == "DB_SCHEMA_CHECK":
        required_columns = {
            "api_tokens": ["scopes", "name", "last_used_at", "expires_at"],
            "transcriptions": ["segment_id"],
            "users": ["max_concurrent_bots", "data"],
            "meetings": ["data", "updated_at"],
        }
        errors = []
        for table, columns in required_columns.items():
            for col in columns:
                rc, out = svc_exec("admin-api", [
                    "python3", "-c",
                    f"import os; from sqlalchemy import create_engine, text;"
                    f"e=create_engine(f\"postgresql://{{os.environ['DB_USER']}}:{{os.environ['DB_PASSWORD']}}@{{os.environ['DB_HOST']}}:{{os.environ['DB_PORT']}}/{{os.environ['DB_NAME']}}\");"
                    f"c=e.connect(); r=c.execute(text(\"SELECT column_name FROM information_schema.columns WHERE table_name='{table}' AND column_name='{col}'\")).fetchone(); c.close();"
                    f"print('OK' if r else 'MISSING')"
                ])
                if "MISSING" in out:
                    errors.append(f"{table}.{col}")
        if errors:
            return False, f"missing columns: {', '.join(errors)}"
        return True, f"all required columns present"

    if url == "DB_USERS_CHECK":
        rc, out = svc_exec("admin-api", [
            "python3", "-c",
            "import os; from sqlalchemy import create_engine, text;"
            "e=create_engine(f\"postgresql://{os.environ['DB_USER']}:{os.environ['DB_PASSWORD']}@{os.environ['DB_HOST']}:{os.environ['DB_PORT']}/{os.environ['DB_NAME']}\");"
            "c=e.connect(); r=c.execute(text('SELECT count(*) FROM users')).scalar(); c.close();"
            "print(r)"
        ])
        if rc == 0 and out.strip().isdigit() and int(out.strip()) > 0:
            return True, f"{out.strip()} users"
        return False, f"users count: {out.strip()}"

    if url == "DB_TOKEN_SCOPES_CHECK":
        rc, out = svc_exec("admin-api", [
            "python3", "-c",
            "import os; from sqlalchemy import create_engine, text;"
            "e=create_engine(f\"postgresql://{os.environ['DB_USER']}:{os.environ['DB_PASSWORD']}@{os.environ['DB_HOST']}:{os.environ['DB_PORT']}/{os.environ['DB_NAME']}\");"
            "c=e.connect(); total=c.execute(text('SELECT count(*) FROM api_tokens')).scalar();"
            "empty=c.execute(text(\"SELECT count(*) FROM api_tokens WHERE scopes = '{}'\")).scalar(); c.close();"
            "print(f'{total},{empty}')"
        ])
        if rc == 0 and "," in out.strip():
            total, empty = out.strip().split(",")
            if int(total) > 0 and int(empty) == 0:
                return True, f"{total} tokens, all have scopes"
            if int(total) == 0:
                return True, "no tokens yet"
            return False, f"{empty}/{total} tokens have empty scopes — backfill needed"
        return False, f"could not check: {out.strip()}"

    # Special: Redis ping via svc_exec
    if url == "REDIS_PING":
        code, out = svc_exec("redis", ["redis-cli", "ping"])
        if code == 0 and "PONG" in out:
            return True, ""
        return False, f"redis-cli ping: {out}"

    # Special: Runtime API health — localhost in compose/lite, K8s readiness in helm
    if url == "RUNTIME_API_HEALTH":
        mode = state_read("deploy_mode", required=True)
        if mode in ("compose", "lite"):
            code, body = http_check("http://localhost:8090/health")
            if code == 200:
                return True, ""
            return False, f"HTTP {code} from localhost:8090/health"
        elif mode == "helm":
            release = state_read("helm_release")
            deploy_name = f"{release}-vexa-runtime-api" if release else "runtime-api"
            try:
                r = subprocess.run(
                    ["kubectl", "get", "deploy", deploy_name,
                     "-o", "jsonpath={.status.readyReplicas}"],
                    capture_output=True, text=True, timeout=10)
                replicas = r.stdout.strip()
                if r.returncode == 0 and replicas and int(replicas) > 0:
                    return True, f"{replicas} ready replicas"
                return False, f"runtime-api: {replicas or '0'} ready replicas"
            except Exception as e:
                return False, str(e)
        return False, f"unknown mode: {mode}"

    # Special: MinIO health — localhost in compose, skipped in lite/helm
    if url == "MINIO_HEALTH":
        mode = state_read("deploy_mode", required=True)
        if mode == "compose":
            code, body = http_check("http://localhost:9000/minio/health/live")
            if code == 200:
                return True, ""
            return False, f"HTTP {code} from localhost:9000"
        elif mode == "helm":
            release = state_read("helm_release")
            sts_name = f"{release}-vexa-minio" if release else "minio"
            try:
                r = subprocess.run(
                    ["kubectl", "get", "statefulset", sts_name,
                     "-o", "jsonpath={.status.readyReplicas}"],
                    capture_output=True, text=True, timeout=10)
                replicas = r.stdout.strip()
                if r.returncode == 0 and replicas and int(replicas) > 0:
                    return True, f"{replicas} ready replicas"
                return False, f"minio: {replicas or '0'} ready replicas"
            except Exception as e:
                return False, str(e)
        return True, f"skipped for {mode} mode"

    # Special: K8s deployment readiness
    if url == "K8S_DEPLOYMENTS_READY":
        try:
            r = subprocess.run(
                ["kubectl", "get", "deploy", "-l", "app.kubernetes.io/name=vexa",
                 "-o", "jsonpath={range .items[*]}{.metadata.name}={.status.readyReplicas}/{.status.replicas} {end}"],
                capture_output=True, text=True, timeout=10)
            if r.returncode != 0:
                return False, f"kubectl failed: {r.stderr.strip()}"
            pairs = r.stdout.strip().split()
            not_ready = []
            for p in pairs:
                if "=" not in p:
                    continue
                name, counts = p.split("=", 1)
                ready, total = counts.split("/")
                if not ready or ready == "None" or int(ready) < 1:
                    not_ready.append(name)
            if not_ready:
                return False, f"not ready: {', '.join(not_ready)}"
            return True, f"{len(pairs)} deployments ready"
        except Exception as e:
            return False, str(e)

    # Special: K8s no CrashLoopBackOff
    if url == "K8S_NO_CRASHLOOP":
        try:
            r = subprocess.run(
                ["kubectl", "get", "pods", "-l", "app.kubernetes.io/name=vexa",
                 "--no-headers"],
                capture_output=True, text=True, timeout=10)
            if "CrashLoopBackOff" in r.stdout:
                crashing = [line.split()[0] for line in r.stdout.strip().split("\n")
                           if "CrashLoopBackOff" in line]
                return False, f"CrashLoopBackOff: {', '.join(crashing)}"
            return True, ""
        except Exception as e:
            return False, str(e)

    # Special: K8s pod restart count
    if url == "K8S_NO_RESTARTS":
        try:
            r = subprocess.run(
                ["kubectl", "get", "pods", "-l", "app.kubernetes.io/name=vexa",
                 "-o", "jsonpath={range .items[*]}{.metadata.name}={range .status.containerStatuses[*]}{.restartCount}{end} {end}"],
                capture_output=True, text=True, timeout=10)
            high_restart = []
            for p in r.stdout.strip().split():
                if "=" not in p:
                    continue
                name, count = p.split("=", 1)
                if count and int(count) > 5:
                    high_restart.append(f"{name}({count})")
            if high_restart:
                return False, f"high restarts: {', '.join(high_restart)}"
            return True, ""
        except Exception as e:
            return False, str(e)

    # Special: K8s secrets exist
    if url == "K8S_SECRETS_EXIST":
        try:
            r = subprocess.run(
                ["kubectl", "get", "secret", "-l", "app.kubernetes.io/name=vexa",
                 "--no-headers"],
                capture_output=True, text=True, timeout=10)
            if r.returncode != 0 or not r.stdout.strip():
                return False, "no vexa secrets found"
            count = len(r.stdout.strip().split("\n"))
            return True, f"{count} secrets"
        except Exception as e:
            return False, str(e)

    # Special: Helm lint
    if url == "HELM_LINT":
        chart_path = os.path.join(ROOT, "deploy", "helm", "charts", "vexa")
        if not os.path.isdir(chart_path):
            return False, f"chart not found: {chart_path}"
        try:
            r = subprocess.run(
                ["helm", "lint", chart_path],
                capture_output=True, text=True, timeout=30)
            if r.returncode == 0:
                return True, ""
            return False, r.stderr.strip() or r.stdout.strip()
        except FileNotFoundError:
            return True, "helm not installed — skipped"
        except Exception as e:
            return False, str(e)

    # Special: Helm template renders
    if url == "HELM_TEMPLATE":
        chart_path = os.path.join(ROOT, "deploy", "helm", "charts", "vexa")
        if not os.path.isdir(chart_path):
            return False, f"chart not found: {chart_path}"
        try:
            r = subprocess.run(
                ["helm", "template", "test-render", chart_path],
                capture_output=True, text=True, timeout=30)
            if r.returncode == 0:
                return True, ""
            return False, r.stderr.strip()
        except FileNotFoundError:
            return True, "helm not installed — skipped"
        except Exception as e:
            return False, str(e)

    # Special: Dashboard WS URL — /api/config must return browser-resolvable wsUrl
    if url == "DASHBOARD_WS_URL":
        dash = state_read("dashboard_url", required=True)
        code, body = http_check(f"{dash}/api/config")
        if code != 200:
            return False, f"HTTP {code} from {dash}/api/config"
        try:
            ws_url = json.loads(body).get("wsUrl", "")
        except Exception as e:
            return False, f"JSON parse error: {e}"
        if not ws_url:
            return False, "wsUrl field missing or empty"
        internal_hosts = ["api-gateway", "meeting-api", "admin-api", "redis", "minio"]
        for h in internal_hosts:
            if h in ws_url:
                return False, f"wsUrl contains internal hostname '{h}': {ws_url}"
        return True, ws_url

    url = url.replace("$GATEWAY_URL", state_read("gateway_url", required=True))
    url = url.replace("$ADMIN_URL", state_read("admin_url", required=True))
    url = url.replace("$DASHBOARD_URL", state_read("dashboard_url", required=True))
    expect = lock.get("expect_code", 200)
    headers = []

    # Some health checks need auth — bootstrap from container if needed
    if lock.get("needs_admin_token"):
        admin_token = state_read("admin_token")
        if not admin_token:
            code_e, val = svc_exec("admin-api", ["printenv", "ADMIN_API_TOKEN"])
            if code_e == 0 and val:
                admin_token = val
                with open(os.path.join(STATE, "admin_token"), "w") as f:
                    f.write(admin_token)
        if admin_token:
            headers.append(f"X-Admin-API-Key: {admin_token}")

    code, body = http_check(url, headers=headers)
    if code == expect:
        return True, ""
    return False, f"HTTP {code} (expected {expect})"


def check_contract(lock):
    """Test API behavior — method, URL, expected response."""
    skip_modes = lock.get("skip_modes", [])
    if skip_modes:
        mode = state_read("deploy_mode")
        if mode in skip_modes:
            return True, f"skipped for {mode} mode"

    gw = state_read("gateway_url", required=True)
    admin = state_read("admin_url", required=True)
    dash = state_read("dashboard_url", required=True)
    token = state_read("api_token")
    admin_token = state_read("admin_token")

    method = lock.get("method", "GET")

    # Special methods that don't use url
    if method == "WS_PING":
        return check_ws_ping(gw, token)
    if method == "TRANSCRIPTION_TEST":
        return check_transcription_token()
    if method == "BOT_STATUS_CHECK":
        return check_bot_status_transitions(gw, token)
    if method == "BROWSER_SESSION_CDP_CHECK":
        return check_browser_session_cdp(gw, token)
    if method == "BOT_RECORDING_CHECK":
        return check_bot_recording_enabled(gw, token)
    if method == "MINIO_WRITABLE":
        return check_minio_writable()
    if method == "SEGMENT_PIPELINE":
        return check_segment_pipeline(gw, token, admin_token)

    url = lock["url"].replace("$GATEWAY_URL", gw).replace("$ADMIN_URL", admin).replace("$DASHBOARD_URL", dash)
    expect = lock.get("expect_code", 200)
    headers = []

    auth = lock.get("auth", "")
    if auth == "api_token" and token:
        headers.append(f"X-API-Key: {token}")
    elif auth == "admin_token" and admin_token:
        headers.append(f"X-Admin-API-Key: {admin_token}")

    if method == "GET":
        code, body = http_check(url, headers=headers)
    else:
        data = lock.get("data", "{}")
        headers.append("Content-Type: application/json")
        cmd = ["curl", "-sf", "-w", "\n%{http_code}", "-o", "-", "-X", method, "-d", data]
        for h in headers:
            cmd += ["-H", h]
        cmd.append(url)
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
            lines = r.stdout.strip().rsplit("\n", 1)
            body = lines[0] if len(lines) > 1 else ""
            code = int(lines[-1]) if lines[-1].isdigit() else 0
        except Exception as e:
            code, body = 0, str(e)

    # expect_code can be a list
    if isinstance(expect, list):
        if code in expect:
            return True, ""
        return False, f"HTTP {code} (expected one of {expect})"
    else:
        if code == expect:
            return True, ""
        return False, f"HTTP {code} (expected {expect})"


def check_browser_session_cdp(gw, token):
    """Create browser session, verify CDP proxy responds (not 502)."""
    import time

    if not token:
        return True, "no API token — skipped"

    # Create session
    try:
        r = subprocess.run(
            ["curl", "-s", "-w", "\n%{http_code}", "-X", "POST",
             "-H", f"X-API-Key: {token}", "-H", "Content-Type: application/json",
             "-d", '{"mode":"browser_session","bot_name":"CDP Check"}',
             f"{gw}/bots"],
            capture_output=True, text=True, timeout=15)
        lines = r.stdout.strip().rsplit("\n", 1)
        code = int(lines[-1]) if lines[-1].isdigit() else 0
        body = lines[0] if len(lines) > 1 else ""
        if code == 403:
            return True, "concurrency limit — skipped"
        if code not in (200, 201, 202):
            return False, f"session creation failed: HTTP {code}"

        session_data = json.loads(body)
        session_token = session_data.get("data", {}).get("session_token", "")
        native_id = session_data.get("native_meeting_id", "")
    except Exception as e:
        return False, f"session creation error: {e}"

    if not session_token:
        return False, "no session_token in response"

    # Wait for container to start — then test CDP twice:
    # once after pod ready, once immediately after to catch IP resolution races
    time.sleep(20)

    # Hit CDP proxy
    try:
        r = subprocess.run(
            ["curl", "-sL", "-w", "\n%{http_code}",
             f"{gw}/b/{session_token}/cdp/json/version"],
            capture_output=True, text=True, timeout=15)
        lines = r.stdout.strip().rsplit("\n", 1)
        cdp_code = int(lines[-1]) if lines[-1].isdigit() else 0
        cdp_body = lines[0] if len(lines) > 1 else ""
    except Exception as e:
        cdp_code = 0
        cdp_body = str(e)

    # Clean up — wait for container to fully stop before next check
    subprocess.run(
        ["curl", "-sf", "-X", "DELETE", f"{gw}/bots/browser_session/{native_id}",
         "-H", f"X-API-Key: {token}"],
        capture_output=True, timeout=10)
    time.sleep(10)

    if cdp_code == 200 and "webSocketDebuggerUrl" in cdp_body:
        return True, "CDP proxy reachable"
    if cdp_code == 502:
        return False, f"CDP proxy 502 — gateway cannot reach browser container: {cdp_body[:100]}"
    return False, f"CDP proxy HTTP {cdp_code}: {cdp_body[:100]}"


def check_bot_recording_enabled(gw, token):
    """Check that meeting-api has RECORDING_ENABLED=true — bots will record audio."""
    rc, val = svc_exec("meeting-api", ["printenv", "RECORDING_ENABLED"])
    if rc != 0:
        return False, "RECORDING_ENABLED not set on meeting-api"
    if val.strip().lower() == "true":
        return True, "RECORDING_ENABLED=true"
    return False, f"RECORDING_ENABLED={val.strip()} — bots will not record audio"


def check_minio_writable():
    """Verify MinIO bucket exists and accepts writes — needed for recordings and browser state."""
    mode = state_read("deploy_mode")
    if mode == "lite":
        return True, "skipped for lite (no local MinIO)"

    rc, out = svc_exec("meeting-api", [
        "python3", "-c",
        "import os,boto3;"
        "ep=os.environ.get('MINIO_ENDPOINT','');"
        "ak=os.environ.get('MINIO_ACCESS_KEY','');"
        "sk=os.environ.get('MINIO_SECRET_KEY','');"
        "bk=os.environ.get('MINIO_BUCKET','vexa');"
        "sc=os.environ.get('MINIO_SECURE','false').lower()=='true';"
        "proto='https' if sc else 'http';"
        "s3=boto3.client('s3',endpoint_url=f'{proto}://{ep}',aws_access_key_id=ak,aws_secret_access_key=sk);"
        "s3.head_bucket(Bucket=bk);"
        "s3.put_object(Bucket=bk,Key='_healthcheck/test.txt',Body=b'ok');"
        "s3.delete_object(Bucket=bk,Key='_healthcheck/test.txt');"
        "print('OK')"
    ])
    if rc == 0 and "OK" in out:
        return True, ""

    rc2, ep = svc_exec("meeting-api", ["printenv", "MINIO_ENDPOINT"])
    if rc2 != 0 or not ep:
        return True, "no MINIO_ENDPOINT configured — skipped"

    return False, f"MinIO bucket not writable — bucket may not exist or credentials wrong. Detail: {out}"


def check_segment_pipeline(gw, token, admin_token):
    """Create bot, inject synthetic segment into Redis, verify it appears in REST transcript."""
    import time
    import uuid

    if not token:
        return True, "no API token — skipped"

    native_id = f"pipeline-check-{int(time.time())}"
    session_uid = str(uuid.uuid4())

    # 1. Create bot to get a valid meeting + JWT
    create_data = json.dumps({
        "platform": "google_meet",
        "native_meeting_id": native_id,
        "bot_name": "Pipeline Check",
        "automatic_leave": {"no_one_joined_timeout": 30000},
    })
    code, body = http_check(
        f"{gw}/bots",
        headers=[f"X-API-Key: {token}", "Content-Type: application/json"])
    # Use POST manually
    try:
        r = subprocess.run(
            ["curl", "-s", "-w", "\n%{http_code}", "-X", "POST", "-d", create_data,
             "-H", f"X-API-Key: {token}", "-H", "Content-Type: application/json",
             f"{gw}/bots"],
            capture_output=True, text=True, timeout=15)
        lines = r.stdout.strip().rsplit("\n", 1)
        code = int(lines[-1]) if lines[-1].isdigit() else 0
        resp_body = lines[0] if len(lines) > 1 else ""
        if code == 403:
            return True, "concurrency limit — skipped"
        if code not in (200, 201, 202):
            return False, f"bot creation failed: HTTP {code}"

        meeting_data = json.loads(resp_body)
        meeting_id = meeting_data.get("id")
    except Exception as e:
        return False, f"bot creation error: {e}"

    # 2. Wait for bot pod + session_start
    time.sleep(10)

    # 3. Inject synthetic transcription segment into Redis
    # Use "transcription" type with "segments" array — matches the collector's expected format
    seg_id = f"pipeline-seg-{int(time.time())}"
    segment_payload = json.dumps({
        "type": "transcription",
        "uid": session_uid,
        "meeting_id": str(meeting_id),
        "platform": "google_meet",
        "segments": [{
            "segment_id": seg_id,
            "speaker": "Pipeline Test Speaker",
            "text": f"pipeline check {native_id}",
            "start": 1.0,
            "end": 3.0,
            "language": "en",
            "completed": True,
        }],
    })
    rc, out = svc_exec("redis", [
        "redis-cli", "XADD", "transcription_segments", "*",
        "payload", segment_payload
    ])
    if rc != 0:
        # Clean up bot
        subprocess.run(["curl", "-sf", "-X", "DELETE", f"{gw}/bots/google_meet/{native_id}",
                        "-H", f"X-API-Key: {token}"], capture_output=True, timeout=10)
        return False, f"redis inject failed: {out}"

    # 4. Wait for collector to process
    time.sleep(15)

    # 5. Check transcript via REST
    try:
        r = subprocess.run(
            ["curl", "-sf", "-H", f"X-API-Key: {token}",
             f"{gw}/transcripts/google_meet/{native_id}"],
            capture_output=True, text=True, timeout=10)
        transcript = json.loads(r.stdout)
        segments = transcript.get("segments", [])
    except Exception as e:
        segments = []

    # 6. Clean up
    subprocess.run(["curl", "-sf", "-X", "DELETE", f"{gw}/bots/google_meet/{native_id}",
                    "-H", f"X-API-Key: {token}"], capture_output=True, timeout=10)

    if len(segments) > 0:
        texts = [s.get("text", "") for s in segments]
        return True, f"{len(segments)} segments: {texts[0][:50]}"
    return False, "0 segments after injecting into Redis — collector pipeline broken"


def check_bot_status_transitions(gw, token):
    """Create a bot, wait up to 30s for status to leave 'requested', then clean up."""
    import time

    if not token:
        return True, "no API token — skipped"

    # Create bot
    native_id = f"status-check-{int(time.time())}"
    create_data = json.dumps({
        "platform": "google_meet",
        "native_meeting_id": native_id,
        "bot_name": "Status Check",
        "automatic_leave": {"no_one_joined_timeout": 30000},
    })
    headers = ["Content-Type: application/json", f"X-API-Key: {token}"]
    cmd = ["curl", "-s", "-w", "\n%{http_code}", "-X", "POST", "-d", create_data,
           f"{gw}/bots"] + [h for hdr in headers for h in ["-H", hdr]]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        lines = r.stdout.strip().rsplit("\n", 1)
        code = int(lines[-1]) if lines[-1].isdigit() else 0
        if code == 403:
            return True, "concurrency limit — skipped (another bot running)"
        if code not in (200, 201, 202):
            return False, f"bot creation failed: HTTP {code}"
    except Exception as e:
        return False, f"bot creation error: {e}"

    # Poll for status transition (max 30s)
    final_status = "requested"
    for i in range(6):
        time.sleep(5)
        try:
            r = subprocess.run(
                ["curl", "-sf", "-H", f"X-API-Key: {token}", f"{gw}/bots/status"],
                capture_output=True, text=True, timeout=10)
            bots = json.loads(r.stdout).get("running_bots", [])
            for b in bots:
                if b.get("native_meeting_id") == native_id:
                    final_status = b.get("data", {}).get("meeting_status") or b.get("meeting_status", "requested")
                    break
        except Exception:
            pass
        if final_status != "requested":
            break

    # Clean up
    subprocess.run(
        ["curl", "-sf", "-X", "DELETE", f"{gw}/bots/google_meet/{native_id}",
         "-H", f"X-API-Key: {token}"],
        capture_output=True, timeout=10)

    if final_status == "requested":
        return False, "bot stuck in 'requested' after 30s — status callbacks not working"
    return True, f"status transitioned to '{final_status}'"


def check_transcription_token():
    """Send real audio to transcription service, verify token not rejected."""
    env_file = os.path.join(ROOT, ".env")
    tx_url = ""
    tx_token = ""
    if os.path.isfile(env_file):
        for line in open(env_file):
            if line.startswith("TRANSCRIPTION_SERVICE_URL="):
                tx_url = line.strip().split("=", 1)[1]
            if line.startswith("TRANSCRIPTION_SERVICE_TOKEN="):
                tx_token = line.strip().split("=", 1)[1]
    if not tx_url:
        # Try from container
        code, val = svc_exec("meeting-api", ["printenv", "TRANSCRIPTION_SERVICE_URL"])
        if code == 0 and val:
            tx_url = val
        code, val = svc_exec("meeting-api", ["printenv", "TRANSCRIPTION_SERVICE_TOKEN"])
        if code == 0 and val:
            tx_token = val
    if not tx_url:
        return True, "no transcription URL configured — skipped"

    test_audio = os.path.join(ROOT, "tests3", "testdata", "test-speech-en.wav")
    if not os.path.isfile(test_audio):
        return False, f"test audio not found: {test_audio} — copy from services/transcription-service/tests/test_audio.wav"

    try:
        r = subprocess.run(
            ["curl", "-s", "-w", "\n%{http_code}", "-X", "POST", tx_url,
             "-H", f"Authorization: Bearer {tx_token}",
             "-F", f"file=@{test_audio}", "-F", "language=en", "-F", "model=large-v3-turbo"],
            capture_output=True, text=True, timeout=30)
        lines = r.stdout.strip().rsplit("\n", 1)
        code = int(lines[-1]) if lines[-1].isdigit() else 0
        if code == 200:
            return True, ""
        if code == 403:
            return False, "token rejected (403) — expired or invalid"
        return False, f"HTTP {code}"
    except Exception as e:
        return False, str(e)


def check_ws_ping(gw, token):
    """WebSocket ping/pong check. Tries websockets module, falls back to HTTP upgrade check."""
    ws_url = gw.replace("http://", "ws://").replace("https://", "wss://")
    ws_url = f"{ws_url}/ws?api_key={token}"
    try:
        r = subprocess.run(
            ["python3", "-c", f"""
import asyncio, json
try:
    import websockets
    async def t():
        async with websockets.connect('{ws_url}') as ws:
            await ws.send(json.dumps({{"action":"ping"}}))
            msg = json.loads(await asyncio.wait_for(ws.recv(), timeout=5))
            if msg.get('type') == 'pong': print('OK')
            else: print('BAD:' + json.dumps(msg))
    asyncio.run(t())
except ImportError:
    # Fallback: check WS endpoint responds to HTTP upgrade
    import urllib.request
    url = '{gw}/ws?api_key={token}'
    req = urllib.request.Request(url, headers={{'Upgrade': 'websocket', 'Connection': 'Upgrade', 'Sec-WebSocket-Version': '13', 'Sec-WebSocket-Key': 'dGVzdA=='}})
    try:
        urllib.request.urlopen(req, timeout=5)
    except urllib.error.HTTPError as e:
        if e.code == 101 or e.code == 426: print('OK')
        else: print('HTTP:' + str(e.code))
    except Exception as e:
        if '101' in str(e) or 'Switching' in str(e): print('OK')
        else: print('FAIL:' + str(e))
"""],
            capture_output=True, text=True, timeout=10
        )
        if "OK" in r.stdout:
            return True, ""
        return False, f"no pong: {r.stdout.strip()} {r.stderr.strip()}"
    except Exception as e:
        return False, str(e)


def bootstrap_creds():
    """Ensure admin_token and api_token exist in .state for contract checks.
    Re-bootstraps if the cached admin_token doesn't validate (stale from a different deploy)."""
    admin_token = state_read("admin_token")
    api_token = state_read("api_token")

    # Quick validation: if we have both, check admin token still works
    if admin_token and api_token:
        admin_url = state_read("admin_url", required=True)
        code, _ = http_check(f"{admin_url}/admin/users?limit=1",
                             headers=[f"X-Admin-API-Key: {admin_token}"])
        if code == 200:
            return  # both valid
        # Stale — clear and re-bootstrap
        for f in ("admin_token", "api_token"):
            p = os.path.join(STATE, f)
            if os.path.exists(p):
                os.remove(p)

    # Get admin token from container env
    admin_token = state_read("admin_token")
    if not admin_token:
        code, val = svc_exec("admin-api", ["printenv", "ADMIN_API_TOKEN"])
        if code == 0 and val:
            admin_token = val
            with open(os.path.join(STATE, "admin_token"), "w") as f:
                f.write(admin_token)

    if not admin_token:
        return  # can't bootstrap without admin token

    admin_url = state_read("admin_url", required=True)
    gw = state_read("gateway_url", required=True)

    # Find or create test user
    code, body = http_check(
        f"{admin_url}/admin/users/email/test@vexa.ai",
        headers=[f"X-Admin-API-Key: {admin_token}"])
    if code == 200:
        try:
            user_id = json.loads(body)["id"]
        except Exception:
            return
    else:
        # Create user
        cmd = ["curl", "-sf", "-X", "POST",
               "-H", f"X-Admin-API-Key: {admin_token}",
               "-H", "Content-Type: application/json",
               "-d", '{"email":"test@vexa.ai","name":"Test User"}',
               f"{admin_url}/admin/users"]
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
            user_id = json.loads(r.stdout)["id"]
        except Exception:
            return

    # Create API token
    cmd = ["curl", "-sf", "-X", "POST",
           "-H", f"X-Admin-API-Key: {admin_token}",
           f"{admin_url}/admin/users/{user_id}/tokens?scopes=bot,browser,tx&name=tests3"]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
        token = json.loads(r.stdout).get("token", "")
        if token:
            with open(os.path.join(STATE, "api_token"), "w") as f:
                f.write(token)
    except Exception:
        pass


RUNNERS = {
    "static": check_static,
    "env": check_env,
    "health": check_health,
    "contract": check_contract,
}


def main():
    # Parse args
    tier_filter = None
    for i, arg in enumerate(sys.argv[1:], 1):
        if arg == "--tier" and i < len(sys.argv) - 1:
            tier_filter = sys.argv[i + 1]

    with open(REGISTRY) as f:
        registry = json.load(f)

    locks = [l for l in registry["locks"] if "tier" in l]
    if tier_filter:
        locks = [l for l in locks if l["tier"] == tier_filter]

    if not locks:
        print(f"  {dim('no checks for tier: ' + str(tier_filter))}")
        return

    # Bootstrap credentials for tiers that need them
    if tier_filter in ("contract", None):
        bootstrap_creds()

    tier_name = tier_filter or "all"
    log("INFO", tier_name, f"starting {len(locks)} checks")
    print()
    print(f"  {tier_name} checks")
    print(f"  {'─' * 46}")

    passed = 0
    failed = 0
    failures = []

    for lock in locks:
        lid = lock["id"]
        tier = lock["tier"]
        symptom = lock.get("symptom", "")
        proves = lock.get("proves", symptom)
        runner = RUNNERS.get(tier)
        if not runner:
            print(f"  {red('SKIP')}  {lid}  (unknown tier: {tier})")
            log("SKIP", lid, "unknown tier", tier)
            continue

        ok, reason = runner(lock)
        if ok:
            passed += 1
            print(f"  {green(' ok ')}  {lid}")
            log("PASS", lid, f"proves: {proves}")
        else:
            failed += 1
            print(f"  {red('FAIL')}  {lid}")
            log("FAIL", lid, reason, f"bug: {symptom}")
            failures.append((lid, lock, reason))

    print(f"  {'─' * 46}")

    if failures:
        print()
        for lid, lock, reason in failures:
            print(f"  {red(lid)}")
            if "file" in lock:
                print(f"    file: {lock['file']}")
            print(f"    {reason}")
            if "symptom" in lock:
                print(f"    bug ({lock.get('found', '?')}): {lock['symptom']}")
            print()
        print(f"  {red(f'{failed} failed')} out of {passed + failed} checks")
        log("INFO", tier_name, f"FAILED: {failed}/{passed + failed}")
        print()
        sys.exit(1)
    else:
        print(f"  {green(f'All {passed} checks pass.')}")
        log("INFO", tier_name, f"ALL PASS: {passed}/{passed}")
        print()


if __name__ == "__main__":
    main()
